<?xml version="1.0" encoding="UTF-8"?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns
         http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
<!-- Created by igraph -->
  <key id="v_name" for="node" attr.name="name" attr.type="string"/>
  <key id="v_abundance" for="node" attr.name="abundance" attr.type="string"/>
  <key id="e_direction" for="edge" attr.name="direction" attr.type="string"/>
  <graph id="G" edgedefault="undirected">
    <node id="n0">
      <data key="v_name">NFKB2</data>
      <data key="v_abundance">NA</data>
    </node>
    <node id="n1">
      <data key="v_name">RELB</data>
      <data key="v_abundance">NA</data>
    </node>
    <node id="n2">
      <data key="v_name">CCL21</data>
      <data key="v_abundance">*</data>
    </node>
    <edge source="n0" target="n2">
      <data key="e_direction">+</data>
    </edge>
    <edge source="n1" target="n2">
      <data key="e_direction">+</data>
    </edge>
  </graph>
</graphml>
